# NextAuth
NEXTAUTH_URL=https://cconbedrock-dashboard.atomai.click
NEXTAUTH_SECRET=your-nextauth-secret-here

# Cognito
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret
COGNITO_ISSUER=https://cognito-idp.REGION.amazonaws.com/REGION_XXXXXXXXX

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECS_CLUSTER_NAME=cc-on-bedrock-devenv
COGNITO_USER_POOL_ID=REGION_XXXXXXXXX

# Domain
DOMAIN_NAME=atomai.click
DEV_SUBDOMAIN=dev

# Infrastructure
VPC_ID=vpc-xxxxxxxxx
PRIVATE_SUBNET_IDS=subnet-xxx,subnet-yyy
SG_DEVENV_OPEN=sg-xxx
SG_DEVENV_RESTRICTED=sg-yyy
SG_DEVENV_LOCKED=sg-zzz
EFS_FILE_SYSTEM_ID=fs-xxxxxxxxx
DEVENV_ALB_LISTENER_ARN=arn:aws:elasticloadbalancing:REGION:ACCOUNT:listener/app/xxx
CODESERVER_PASSWORD=your-password-here

# AgentCore (optional, for /api/ai/runtime)
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:REGION:ACCOUNT:runtime/xxx
AGENTCORE_GATEWAY_URL=https://xxx.gateway.bedrock-agentcore.REGION.amazonaws.com/mcp
AGENTCORE_MEMORY_ID=xxx

# Usage Tracking
USAGE_TABLE_NAME=cc-on-bedrock-usage
